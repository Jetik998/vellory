
# .env.example
# Скопируйте этот файл в .env и заполните своими значениями!

ENVIRONMENT=development

# Секретный ключ для JWT
SECRET_KEY=your_super_secret_jwt_key_here

# Алгоритм для подписи JWT (обычно оставляют HS256)
ALGORITHM=HS256

# Время жизни токена в секундах
ACCESS_TOKEN_EXPIRE_SECONDS=60
REFRESH_TOKEN_EXPIRE_SECONDS=600

# Настройки базы данных PostgreSQL
# (для Docker Compose обычно DB_HOST=db)
DB_HOST=db
DB_PORT=5432
DB_USER=your_db_username
DB_PASS=your_db_password
DB_NAME=your_db_name

# Настройки тестовой базы данных PostgreSQL
# (для локальных тестов)
TDB_HOST=localhost
TDB_PORT=5432
TDB_USER=your_test_db_username
TDB_PASS=your_test_db_password
TDB_NAME=your_test_db_name

# Настройки Redis
# LOCAL_REDIS_HOST — для локального запуска
# REDIS_HOST — для Docker Compose
LOCAL_REDIS_HOST=localhost
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_DB_COUNT=1

# Настройки ограничения запросов (rate limiting)
# Количество разрешённых запросов
RATE_LIMIT_TIMES=20
# Временной интервал в секундах
RATE_LIMIT_SECONDS=30